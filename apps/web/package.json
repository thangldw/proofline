{
  "name": "@proofline/web",
  "private": true,
  "version": "0.14.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run check:egress",
    "check:egress": "node scripts/check-egress.mjs",
    "test:e2e": "playwright test",
    "test": "tsc -b && node --test scripts/check-egress.test.mjs && vitest run src"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.4.3",
    "vitest": "^4.0.17"
  }
}
