{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Proofline",
  "version": "0.14.16",
  "identifier": "io.github.thangldw.proofline",
  "build": {
    "frontendDist": "../loading"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Proofline",
        "width": 1440,
        "height": 960,
        "minWidth": 960,
        "minHeight": 680,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset:; style-src 'self' 'unsafe-inline'; connect-src http://127.0.0.1:*; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/proofline-sidecar"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "windows": {
      "digestAlgorithm": "sha256"
    }
  }
}
