# Host port exposed by Docker Compose.
PROOFLINE_API_PORT=8000

# Override these if the backend uses another module layout or health route.
PROOFLINE_ASGI_APP=proofline.main:app
PROOFLINE_HEALTH_PATH=/health

# AI is disabled by default. Use openai_compatible for Qwen, DeepSeek, Ollama,
# vLLM, or another compatible endpoint. Remote endpoints require explicit opt-in.
PROOFLINE_AI_PROVIDER=disabled
PROOFLINE_AI_BASE_URL=
PROOFLINE_AI_MODEL=
PROOFLINE_AI_API_KEY=
PROOFLINE_EMBEDDING_PROVIDER=disabled
PROOFLINE_EMBEDDING_BASE_URL=
PROOFLINE_EMBEDDING_MODEL=
PROOFLINE_EMBEDDING_API_KEY=
PROOFLINE_ALLOW_REMOTE_AI=false
